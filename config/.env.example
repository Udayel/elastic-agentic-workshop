# Elastic Configuration
ES_URL=https://your-deployment.es.us-east-1.aws.elastic.cloud:443
ES_API_KEY=your-elastic-api-key-here

# AWS Configuration (use aws configure or IAM role)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# AgentCore Runtime Configuration
AGENTCORE_RUNTIME_ID=travel-agent-runtime
AGENTCORE_GATEWAY_URL=https://gateway.agentcore.us-east-1.amazonaws.com
AGENTCORE_MEMORY_NAMESPACE=travel-agent-memory

# Cognito Configuration
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=your-app-client-id
COGNITO_DOMAIN=your-app-domain.auth.us-east-1.amazoncognito.com

# OAuth Configuration
OAUTH_CALLBACK_URL=http://localhost:8080/callback
OAUTH_SCOPES=openid profile email

# MCP Server Configuration
MCP_SERVER_PORT=8000
MCP_SERVER_HOST=0.0.0.0

# Application Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development

# Service-Linked Role (IAM)
SERVICE_ROLE_ARN=arn:aws:iam::123456789012:role/AgentCoreServiceRole

# Session Configuration
SESSION_TIMEOUT_SECONDS=3600
MAX_CONVERSATION_TURNS=50

# Security
ENABLE_ENCRYPTION=true
KMS_KEY_ID=your-kms-key-id
